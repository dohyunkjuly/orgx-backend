{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false
  },
  "projects": {
    "@lib/core": {
      "type": "library",
      "root": "lib/core",
      "sourceRoot": "lib/core",
      "entryFile": "index",
      "compilerOptions": {
        "tsConfigPath": "lib/core/tsconfig.lib.json"
      }
    },
    "@lib/modules": {
      "type": "library",
      "root": "lib/modules",
      "sourceRoot": "lib/modules",
      "entryFile": "index",
      "compilerOptions": {
        "tsConfigPath": "lib/modules/tsconfig.lib.json"
      }
    }
  }
}