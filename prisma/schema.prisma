// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


// ─── Enums ────────────────────────────────────

enum Role {
  ADMIN
  MEMBER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

// ─── User ─────────────────────────────────────

model User {
  id              String       @id @default(cuid(2))
  email           String       @unique
  passwordHash    String
  role            Role         @default(MEMBER)
  status          MemberStatus @default(PENDING)
  isEmailVerified Boolean      @default(false)

  // Profile
  fullName     String
  gender       Gender
  phone        String?

  // Academic details
  qualification String
  degreeDate    DateTime?
  university    String
  department    String
  designation   String

  // Timestamps
  joinedAt     DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  refreshTokens           UserRefreshToken[]
  emailVerificationTokens UserEmailVerificationToken[]
  passwordResetTokens     UserPasswordResetToken[]

  @@map("users")
}

model UserRefreshToken {
  id        String   @id @default(cuid(2))
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("user_refresh_token")
}

model UserEmailVerificationToken {
  id         String    @id @default(cuid(2))
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?

  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("user_email_verification_tokens")
}

model UserPasswordResetToken {
  id         String    @id @default(cuid(2))
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?

  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("user_password_reset_tokens")
}
